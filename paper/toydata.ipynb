import numpy as np

def make_toy_genotypes(n_samples=200, n_variants=2000, seed=0):
    rng = np.random.default_rng(seed)

    # positions spaced across 1Mb (monotone increasing)
    pos = np.sort(rng.integers(1, 1_000_000, size=n_variants))

    # simple independent binomial(2,p) genotypes (unphased 0/1/2)
    p = rng.uniform(0.05, 0.5, size=n_variants)
    G = rng.binomial(2, p, size=(n_samples, n_variants)).astype(float)

    return G, pos


from ld_estimates.estimators import r2T, r2BS  # keep it minimal at first

r2_estimators = {
    "Samp": r2T,
    "BS": r2BS,
}



import numpy as np
from paper.experiments import run_experiment, collect_bias_variance_results
from paper.plotting import plot_rmse_distribution_by_bin

G, pos = make_toy_genotypes(n_samples=200, n_variants=2000, seed=1)

distance_bins = np.array([0, 10_000, 100_000, 1_000_000])
n_values = [10, 20]

results = run_experiment(
    G=G,
    pos=pos,
    n_values=n_values,
    r2_estimators=r2_estimators,
    distance_bins=distance_bins,
    max_pairs_per_bin=200,
    n_rep=5,
    seed=123,
    n_jobs=1,   # set >1 later
)

df = collect_bias_variance_results(results, n_values, distance_bins, r2_estimators)

# add binlabel expected by plotting.py: "start-end"
binlabels = [f"{int(distance_bins[i])}-{int(distance_bins[i+1])}" for i in range(len(distance_bins)-1)]
df["binlabel"] = df["bin"].map(dict(enumerate(binlabels)))

plot_rmse_distribution_by_bin(df, statistic="rmse", title="Toy smoke test", show_legend=True)
